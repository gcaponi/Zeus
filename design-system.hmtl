        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><i data-lucide="shield-check" size="18"></i> ShieldCheck</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><i data-lucide="workflow" size="18"></i> Workflow</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><i data-lucide="check-circle-2" size="18"></i> CheckCircle2</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><i data-lucide="loader-2" size="18"></i> Loader2</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><i data-lucide="mail" size="18"></i> Mail</span>
        <span style="display:inline-flex; align-items:center; gap:0.4rem;"><i data-lucide="map-pin" size="18"></i> MapPin</span>
